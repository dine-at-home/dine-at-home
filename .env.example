# ── DatHome frontend (dine-at-home) env (example) ────────────────────────────
# Copy to .env.local for local dev. In production set these in the Vercel dashboard.

# Backend API base. Server-side only (not exposed to the browser).
# Production: https://api.datthome.com/api
BASE_URL=http://localhost:3001/api

# Client-exposed (NEXT_PUBLIC_*). Safe to ship to the browser.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google OAuth client id (used by the sign-in flow)
GOOGLE_CLIENT_ID=
